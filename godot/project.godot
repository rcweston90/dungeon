; Engine configuration file.
; Generated for the Dungeon Forge Godot port.
; See the JS prototype at ../index.html for the reference implementation.

config_version=5

[application]

config/name="Dungeon Forge"
config/description="Deterministic procedural dungeon generator (Godot 4 port of the Three.js prototype)."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"

[rendering]

environment/defaults/default_clear_color=Color(0.027, 0.027, 0.047, 1)
anti_aliasing/quality/msaa_3d=1

[debug]

; This is a Dictionary-heavy data port, so min()/max()/dict-field access often
; infer as Variant. Don't escalate those style warnings to hard errors.
gdscript/warnings/treat_warnings_as_errors=false
gdscript/warnings/inference_on_variant=0
gdscript/warnings/unsafe_call_argument=0
gdscript/warnings/unsafe_method_access=0
gdscript/warnings/unsafe_property_access=0
